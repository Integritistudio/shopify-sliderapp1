{% if block.settings.enable_slider %}
  {% style %}
    #shopify-block-{{ block.id }},
    #shopify-block-{{ block.id }} .slideease-app-block {
      display: block;
      width: 100%;
      max-width: 100%;
      height: auto;
      min-height: 0;
      margin-inline: 0;
      padding-inline: 0;
      overflow: visible;
    }

    #shopify-block-{{ block.id }} .slideease-heading {
      width: min(100% - 2rem, 1200px);
      margin: 0 auto 1.25rem;
      color: rgb(var(--color-foreground, 18 18 18));
      font: inherit;
      font-size: clamp(1.5rem, 3vw, 2.5rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.035em;
      text-align: center;
    }

    #shopify-block-{{ block.id }} .slideease-app-block > .se-root {
      display: block;
      height: auto;
      min-height: 0;
      margin-block: 0;
    }
  {% endstyle %}

  <div
    class="slideease-app-block"
    data-slider-id="{{ block.settings.slider_id | escape }}"
    style="margin-top: {{ block.settings.padding_top }}px; margin-bottom: {{ block.settings.padding_bottom }}px;"
  >
    {% if block.settings.heading != blank %}
      <h2 class="slideease-heading">
        {{ block.settings.heading | escape }}
      </h2>
    {% endif %}
    <script
      src="https://cement-qualify-entities-portable.trycloudflare.com/slider-cdn.js?id={{ block.settings.slider_id | url_encode }}&shop={{ shop.permanent_domain | url_encode }}&v=12"
      defer
    ></script>
  </div>
{% endif %}

{% schema %}
{
  "name": "SlideEase Slider",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "slider_id",
      "label": "Slider ID",
      "info": "Paste the numeric Slider ID from the SlideEase app"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable slider",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Optional heading",
      "info": "Leave empty to hide the heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 16
    }
  ]
}
{% endschema %}
