{% comment %}
  Enhanced Product Slider Block for Shopify
  Fixed responsive behavior and products per view settings
{% endcomment %}

<section class="product-slider-section" id="slider-{{ block.id }}">
  {% assign collection = collections[block.settings.collection] %}
  {% assign products_per_view = block.settings.products_per_view | default: 4 %}
  {% assign product_limit = block.settings.product_limit | default: 12 %}
  {% assign autoplay_enabled = block.settings.enable_autoplay | default: false %}
  {% assign slide_duration = block.settings.slide_duration | default: 4000 %}
  
  {% if block.settings.heading != blank %}
    <h2 class="section-heading">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if collection != blank and collection.products.size > 0 %}
    <div class="slider-container" 
         data-products-per-view="{{ products_per_view }}"
         data-autoplay="{{ autoplay_enabled }}"
         data-slide-duration="{{ slide_duration }}">
      <div class="slider-wrapper" id="sliderWrapper-{{ block.id }}">
        {% for product in collection.products limit: product_limit %}
          <div class="product-card">
            {% comment %} Sale Badge {% endcomment %}
            {% if product.compare_at_price > product.price %}
              <div class="sale-badge">Sale</div>
            {% endif %}
            
            {% comment %} Sold Out Badge {% endcomment %}
            {% unless product.available %}
              <div class="sold-out-badge">Sold Out</div>
            {% endunless %}
            
            {% comment %} Product Image {% endcomment %}
            <a href="{{ product.url }}" class="product-link">
              <div class="product-image">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '400x400' }}" 
                       alt="{{ product.title | escape }}" 
                       loading="lazy">
                {% else %}
                  <div class="no-image-placeholder">
                    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21,15 16,10 5,21"/>
                    </svg>
                  </div>
                {% endif %}
              </div>
              
              {% comment %} Product Info {% endcomment %}
              <div class="product-info">
                <div class="product-title">{{ product.title | truncate: 60 }}</div>
                <div class="price-container">
                  {% if product.compare_at_price > product.price %}
                    <span class="original-price">{{ product.compare_at_price | money }}</span>
                    <span class="from-text">From</span>
                    <span class="current-price">{{ product.price | money }}</span>
                  {% else %}
                    <span class="regular-price">{{ product.price | money }}</span>
                  {% endif %}
                </div>
                
                {% comment %} Color Options {% endcomment %}
                {% if product.options contains 'Color' %}
                  {% assign color_option_index = 0 %}
                  {% for option in product.options %}
                    {% if option == 'Color' %}
                      {% assign color_option_index = forloop.index0 %}
                      {% break %}
                    {% endif %}
                  {% endfor %}
                  
                  <div class="color-options">
                    {% assign color_values = product.options_with_values[color_option_index].values | slice: 0, 5 %}
                    {% for color_value in color_values %}
                      {% assign color_class = color_value | downcase | replace: ' ', '-' | replace: "'", '' %}
                      <div class="color-dot color-{{ color_class }}" 
                           data-color="{{ color_value }}" 
                           title="{{ color_value }}">
                      </div>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
      
      {% comment %} Navigation Arrows {% endcomment %}
      {% assign limited_products = collection.products | slice: 0, product_limit %}
      {% if limited_products.size > products_per_view %}
        <button class="nav-btn prev" id="prevBtn-{{ block.id }}" aria-label="Previous">‹</button>
        <button class="nav-btn next" id="nextBtn-{{ block.id }}" aria-label="Next">›</button>
        
        {% comment %} Play/Pause Button for Autoplay {% endcomment %}
        {% if autoplay_enabled %}
          <button class="play-pause-btn" id="playPauseBtn-{{ block.id }}" aria-label="Play/Pause autoplay">
            <svg class="play-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="5,3 19,12 5,21"></polygon>
            </svg>
            <svg class="pause-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display: none;">
              <rect x="6" y="4" width="4" height="16"></rect>
              <rect x="14" y="4" width="4" height="16"></rect>
            </svg>
          </button>
        {% endif %}
      {% endif %}
    </div>
    
    {% comment %} Slider Dots {% endcomment %}
    {% if limited_products.size > products_per_view %}
      <div class="slider-dots" id="sliderDots-{{ block.id }}">
        {% assign total_slides = limited_products.size | minus: products_per_view | plus: 1 %}
        {% for i in (1..total_slides) %}
          <div class="dot{% if forloop.first %} active{% endif %}" data-slide="{{ forloop.index0 }}"></div>
        {% endfor %}
      </div>
    {% endif %}
  {% else %}
    <div class="empty-state">
      <p>Please select a collection with products to display</p>
    </div>
  {% endif %}
</section>



<style>
  .product-slider-section {
    margin: 40px auto;
    padding: 0 20px;
    max-width: 1400px;
  }

  .section-heading {
    text-align: center;
    margin-bottom: 2rem;
    color: {{ block.settings.heading_color | default: '#2c3e50' }};
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }

  .slider-container {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .slider-wrapper {
    display: flex;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0 10px;
  }

  .product-card {
    flex-shrink: 0;
    background: {{ block.settings.card_bg_color | default: 'white' }};
    margin: 0 10px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    box-sizing: border-box;
  }

  /* Desktop: Dynamic width based on products per view */
  .slider-container[data-products-per-view="1"] .product-card { 
    width: calc(100% - 20px); 
    min-width: calc(100% - 20px); 
  }
  .slider-container[data-products-per-view="2"] .product-card { 
    width: calc(50% - 20px); 
    min-width: calc(50% - 20px); 
  }
  .slider-container[data-products-per-view="3"] .product-card { 
    width: calc(33.333% - 20px); 
    min-width: calc(33.333% - 20px); 
  }
  .slider-container[data-products-per-view="4"] .product-card { 
    width: calc(25% - 20px); 
    min-width: calc(25% - 20px); 
  }
  .slider-container[data-products-per-view="5"] .product-card { 
    width: calc(20% - 20px); 
    min-width: calc(20% - 20px); 
  }
  .slider-container[data-products-per-view="6"] .product-card { 
    width: calc(16.666% - 20px); 
    min-width: calc(16.666% - 20px); 
  }

  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.15);
  }

  .product-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .sale-badge,
  .sold-out-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    z-index: 2;
    text-transform: uppercase;
  }

  .sale-badge {
    background: {{ block.settings.sale_color | default: '#ff4757' }};
    color: white;
  }

  .sold-out-badge {
    background: #2f3542;
    color: white;
  }

  .product-image {
    width: 100%;
    height: 200px;
    background-size: cover;
    background-position: center;
    transition: transform 0.3s ease;
    position: relative;
    overflow: hidden;
    background-color: #f8f9fa;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-image img {
    transform: scale(1.05);
  }

  .no-image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ccc;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  }

  .product-info {
    padding: 20px;
  }

  .product-title {
    font-size: 14px;
    color: {{ block.settings.text_color | default: '#2c3e50' }};
    margin-bottom: 12px;
    line-height: 1.4;
    height: 40px;
    overflow: hidden;
    font-weight: 600;
  }

  .price-container {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 15px;
    flex-wrap: wrap;
  }

  .original-price {
    color: #95a5a6;
    text-decoration: line-through;
    font-size: 14px;
  }

  .from-text {
    color: #7f8c8d;
    font-size: 12px;
  }

  .current-price {
    color: {{ block.settings.sale_color | default: '#e74c3c' }};
    font-weight: bold;
    font-size: 16px;
  }

  .regular-price {
    color: {{ block.settings.text_color | default: '#2c3e50' }};
    font-weight: bold;
    font-size: 16px;
  }

  .color-options {
    display: flex;
    gap: 8px;
    margin-bottom: 15px;
    flex-wrap: wrap;
  }

  .color-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid #ecf0f1;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .color-dot:hover {
    transform: scale(1.2);
  }

  /* Color classes */
  .color-black { background-color: #2c3e50; }
  .color-white { background-color: #ffffff; }
  .color-gray, .color-grey { background-color: #95a5a6; }
  .color-orange { background-color: #e67e22; }
  .color-blue { background-color: #3498db; }
  .color-cream { background-color: #f4f1de; }
  .color-red { background-color: #e74c3c; }
  .color-green { background-color: #2ecc71; }
  .color-yellow { background-color: #f1c40f; }
  .color-purple { background-color: #9b59b6; }
  .color-pink { background-color: #e91e63; }
  .color-brown { background-color: #8b4513; }
  .color-navy { background-color: #2c3e50; }
  .color-beige { background-color: #f5f5dc; }

  .nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: white;
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: #2c3e50;
  }

  .nav-btn:hover {
    background: #2c3e50;
    color: white;
    transform: translateY(-50%) scale(1.1);
  }

  .nav-btn.prev {
    left: 20px;
  }

  .nav-btn.next {
    right: 20px;
  }

  .play-pause-btn {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(44, 62, 80, 0.9);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    color: white;
    transition: all 0.3s ease;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
  }

  .play-pause-btn:hover {
    background: rgba(44, 62, 80, 1);
    transform: scale(1.1);
  }

  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 30px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #bdc3c7;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background: #2c3e50;
    transform: scale(1.2);
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: #6b7280;
    font-style: italic;
    font-size: 1.1rem;
  }

  /* Responsive Design - Fixed Logic */
  @media (max-width: 1024px) {
    /* On tablets, reduce products shown for higher counts */
    .slider-container[data-products-per-view="5"] .product-card,
    .slider-container[data-products-per-view="6"] .product-card {
      width: calc(25% - 20px);
      min-width: calc(25% - 20px);
    }
    
    .slider-container[data-products-per-view="4"] .product-card {
      width: calc(33.333% - 20px);
      min-width: calc(33.333% - 20px);
    }
  }

  @media (max-width: 768px) {
    /* On mobile landscape, show max 2 products */
    .slider-container[data-products-per-view="3"] .product-card,
    .slider-container[data-products-per-view="4"] .product-card,
    .slider-container[data-products-per-view="5"] .product-card,
    .slider-container[data-products-per-view="6"] .product-card {
      width: calc(50% - 20px);
      min-width: calc(50% - 20px);
    }
    
    .product-image {
      height: 180px;
    }
    
    .nav-btn {
      width: 40px;
      height: 40px;
      font-size: 16px;
    }

    .play-pause-btn {
      width: 35px;
      height: 35px;
    }
  }

  @media (max-width: 480px) {
    /* On mobile portrait, show only 1 product for 3+ products setting */
    .slider-container[data-products-per-view="3"] .product-card,
    .slider-container[data-products-per-view="4"] .product-card,
    .slider-container[data-products-per-view="5"] .product-card,
    .slider-container[data-products-per-view="6"] .product-card {
      width: calc(100% - 20px);
      min-width: calc(100% - 20px);
    }
    
    /* Keep 2 products setting as 2 on mobile */
    .slider-container[data-products-per-view="2"] .product-card {
      width: calc(50% - 20px);
      min-width: calc(50% - 20px);
    }
    
    .product-image {
      height: 160px;
    }
    
    .nav-btn.prev {
      left: 10px;
    }
    
    .nav-btn.next {
      right: 10px;
    }

    .play-pause-btn {
      top: 15px;
      right: 15px;
      width: 32px;
      height: 32px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const blockId = '{{ block.id }}';
    const sliderWrapper = document.getElementById('sliderWrapper-' + blockId);
    const prevBtn = document.getElementById('prevBtn-' + blockId);
    const nextBtn = document.getElementById('nextBtn-' + blockId);
    const playPauseBtn = document.getElementById('playPauseBtn-' + blockId);
    const dotsContainer = document.getElementById('sliderDots-' + blockId);
    
    if (!sliderWrapper) return;
    
    const container = sliderWrapper.closest('.slider-container');
    const productsPerView = parseInt(container.dataset.productsPerView) || 4;
    const autoplayEnabled = container.dataset.autoplay === 'true';
    const slideDuration = parseInt(container.dataset.slideDuration) || 4000;
    const products = sliderWrapper.querySelectorAll('.product-card');
    const totalProducts = products.length;
    
    // Calculate effective products per view based on screen size
    function getEffectiveProductsPerView() {
      const screenWidth = window.innerWidth;
      let effectiveProductsPerView = productsPerView;
      
      if (screenWidth <= 480) {
        // Mobile portrait
        if (productsPerView >= 3) {
          effectiveProductsPerView = 1;
        } else if (productsPerView === 2) {
          effectiveProductsPerView = 2;
        }
      } else if (screenWidth <= 768) {
        // Mobile landscape/tablet
        if (productsPerView >= 3) {
          effectiveProductsPerView = 2;
        }
      } else if (screenWidth <= 1024) {
        // Tablet
        if (productsPerView === 6) {
          effectiveProductsPerView = 4;
        } else if (productsPerView === 5) {
          effectiveProductsPerView = 4;
        } else if (productsPerView === 4) {
          effectiveProductsPerView = 3;
        }
      }
      
      return Math.min(effectiveProductsPerView, totalProducts);
    }
    
    let currentSlide = 0;
    let autoSlideInterval;
    let isAutoplayActive = autoplayEnabled;
    let effectiveProductsPerView = getEffectiveProductsPerView();
    let maxSlides = Math.max(0, totalProducts - effectiveProductsPerView);
    
    if (totalProducts <= effectiveProductsPerView) {
      // Hide navigation if not needed
      if (prevBtn) prevBtn.style.display = 'none';
      if (nextBtn) nextBtn.style.display = 'none';
      if (dotsContainer) dotsContainer.style.display = 'none';
      return;
    }
    
    function updateSlider() {
      const cardWidth = products[0].offsetWidth + 20; // Including margin
      const translateX = -currentSlide * cardWidth;
      sliderWrapper.style.transform = 'translateX(' + translateX + 'px)';
      
      // Update dots
      if (dotsContainer) {
        const dots = dotsContainer.querySelectorAll('.dot');
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === currentSlide);
        });
      }
    }
    
    function nextSlide() {
      if (currentSlide < maxSlides) {
        currentSlide++;
      } else {
        currentSlide = 0;
      }
      updateSlider();
    }
    
    function prevSlide() {
      if (currentSlide > 0) {
        currentSlide--;
      } else {
        currentSlide = maxSlides;
      }
      updateSlider();
    }
    
    function goToSlide(slideIndex) {
      currentSlide = Math.max(0, Math.min(slideIndex, maxSlides));
      updateSlider();
    }
    
    function startAutoSlide() {
      if (autoplayEnabled && isAutoplayActive) {
        stopAutoSlide();
        autoSlideInterval = setInterval(nextSlide, slideDuration);
        updatePlayPauseIcon();
      }
    }
    
    function stopAutoSlide() {
      if (autoSlideInterval) {
        clearInterval(autoSlideInterval);
        autoSlideInterval = null;
      }
    }
    
    function toggleAutoplay() {
      isAutoplayActive = !isAutoplayActive;
      if (isAutoplayActive) {
        startAutoSlide();
      } else {
        stopAutoSlide();
      }
      updatePlayPauseIcon();
    }
    
    function updatePlayPauseIcon() {
      if (playPauseBtn) {
        const playIcon = playPauseBtn.querySelector('.play-icon');
        const pauseIcon = playPauseBtn.querySelector('.pause-icon');
        
        if (isAutoplayActive && autoSlideInterval) {
          playIcon.style.display = 'none';
          pauseIcon.style.display = 'block';
        } else {
          playIcon.style.display = 'block';
          pauseIcon.style.display = 'none';
        }
      }
    }
    
    function updateDotsContainer() {
      if (!dotsContainer) return;
      
      // Clear existing dots
      dotsContainer.innerHTML = '';
      
      // Create new dots based on current maxSlides
      for (let i = 0; i <= maxSlides; i++) {
        const dot = document.createElement('div');
        dot.className = 'dot' + (i === currentSlide ? ' active' : '');
        dot.dataset.slide = i;
        dotsContainer.appendChild(dot);
      }
    }
    
    function handleResize() {
      const newEffectiveProductsPerView = getEffectiveProductsPerView();
      
      if (newEffectiveProductsPerView !== effectiveProductsPerView) {
        effectiveProductsPerView = newEffectiveProductsPerView;
        maxSlides = Math.max(0, totalProducts - effectiveProductsPerView);
        
        // Reset current slide if it's beyond new max
        if (currentSlide > maxSlides) {
          currentSlide = maxSlides;
        }
        
        // Show/hide navigation based on need
        const needsNavigation = totalProducts > effectiveProductsPerView;
        if (prevBtn) prevBtn.style.display = needsNavigation ? 'block' : 'none';
        if (nextBtn) nextBtn.style.display = needsNavigation ? 'block' : 'none';
        if (dotsContainer) dotsContainer.style.display = needsNavigation ? 'flex' : 'none';
        
        if (needsNavigation) {
          updateDotsContainer();
        }
      }
      
      updateSlider();
    }
    
    // Event listeners
    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        nextSlide();
        if (autoplayEnabled) {
          stopAutoSlide();
          setTimeout(startAutoSlide, slideDuration * 2);
        }
      });
    }
    
    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        prevSlide();
        if (autoplayEnabled) {
          stopAutoSlide();
          setTimeout(startAutoSlide, slideDuration * 2);
        }
      });
    }
    
    if (playPauseBtn) {
      playPauseBtn.addEventListener('click', toggleAutoplay);
    }
    
    // Dot click handlers
    if (dotsContainer) {
      dotsContainer.addEventListener('click', function(e) {
        if (e.target.classList.contains('dot')) {
          const slideIndex = parseInt(e.target.dataset.slide);
          goToSlide(slideIndex);
          if (autoplayEnabled) {
            stopAutoSlide();
            setTimeout(startAutoSlide, slideDuration * 2);
          }
        }
      });
    }
    
    // Pause auto-slide on hover
    container.addEventListener('mouseenter', function() {
      if (autoplayEnabled) stopAutoSlide();
    });
    
    container.addEventListener('mouseleave', function() {
      if (autoplayEnabled && isAutoplayActive) startAutoSlide();
    });
    
    // Touch support for mobile
    let startX = 0;
    let isDragging = false;
    
    container.addEventListener('touchstart', function(e) {
      startX = e.touches[0].clientX;
      isDragging = true;
      if (autoplayEnabled) stopAutoSlide();
    });
    
    container.addEventListener('touchmove', function(e) {
      if (!isDragging) return;
      e.preventDefault();
    });
    
    container.addEventListener('touchend', function(e) {
      if (!isDragging) return;
      isDragging = false;
      
      const endX = e.changedTouches[0].clientX;
      const diffX = startX - endX;
      
      if (Math.abs(diffX) > 50) {
        if (diffX > 0) {
          nextSlide();
        } else {
          prevSlide();
        }
      }
      
      if (autoplayEnabled && isAutoplayActive) {
        setTimeout(startAutoSlide, slideDuration * 2);
      }
    });
    
    // Initialize
    updateDotsContainer();
    updateSlider();
    if (autoplayEnabled) {
      startAutoSlide();
    }
    updatePlayPauseIcon();
    
    // Handle window resize
    window.addEventListener('resize', handleResize);
  });
</script>

{% schema %}
{
  "name": "Product Slider",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_per_view",
      "label": "Products per view",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "info": "Number of products visible at once (automatically adjusts on mobile)"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Maximum products to show",
      "min": 3,
      "max": 50,
      "step": 1,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": false,
      "info": "Automatically advance slides"
    },
{
  "type": "range",
  "id": "slide_duration",
